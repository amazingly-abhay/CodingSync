{
  "manifest_version": 3,
  "name": "CodingSync",
  "version": "1.0.0",
  "description": "Auto-sync accepted solutions to GitHub",
  "permissions": ["storage", "scripting", "tabs", "alarms", "identity"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://www.codechef.com/*",
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.geeksforgeeks.org/*",
        "https://www.codechef.com/*",
        "https://codeforces.com/*",
        "https://atcoder.jp/*"
      ],
      "js": ["content.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "core/*.js",
        "plugins/*.js",
        "plugins/**/*.js",
        "shared/*.js",
        "utils/*.js"
      ],
      "matches": [
        "https://leetcode.com/*",
        "https://www.geeksforgeeks.org/*",
        "https://www.codechef.com/*",
        "https://codeforces.com/*",
        "https://atcoder.jp/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
