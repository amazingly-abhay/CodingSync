{
  "manifest_version": 3,
  "name": "CodingSync",
  "version": "1.0.0",
  "description": "Auto-sync accepted solutions to GitHub",
  "permissions": ["storage", "scripting", "tabs", "alarms", "identity"],
  "key":"",
  "host_permissions": [
    "https://leetcode.com/problems/*",
    "https://www.geeksforgeeks.org/problems/*",
    "https://www.codechef.com/*",
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["inject/leetcode-network.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.geeksforgeeks.org/*",
        "https://practice.geeksforgeeks.org/*",
        "https://geeksforgeeks.org/*",
        "https://www.codechef.com/*",
        "https://codeforces.com/*",
        "https://atcoder.jp/*"
      ],
      "js": ["content-bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/CodingSync-icon.png"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/CodingSync-icon.png",
    "48": "icons/CodingSync-icon.png",
    "128": "icons/CodingSync-icon.png"
  }
}
